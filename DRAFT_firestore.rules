rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['stats', 'city', 'updatedAt']) 
        && data.keys().size() == 3
        && data.stats is map
        && data.city is map
        && data.updatedAt is timestamp;
    }

    function isValidHabit(data) {
      return data.keys().hasAll(['title', 'type', 'completedDates', 'createdAt', 'targetCount', 'goldReward', 'expReward', 'difficulty', 'currentStreak'])
        && data.keys().size() == 9
        && data.title is string && data.title.size() <= 200
        && data.type in ['daily', 'weekly', 'monthly']
        && data.completedDates is list
        && data.createdAt is timestamp
        && data.targetCount is number
        && data.goldReward is number
        && data.expReward is number
        && data.difficulty is number
        && data.currentStreak is number;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['timestamp', 'type', 'message', 'change', 'unit'])
        && data.keys().size() == 5
        && data.timestamp is timestamp
        && data.type in ['habit', 'city', 'economy', 'system']
        && data.message is string && data.message.size() <= 500
        && data.change is number
        && data.unit in ['hp', 'gold', 'silver', 'exp', 'pop'];
    }

    // --- Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users shouldn't list each other
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if isOwner(userId) 
        && isValidUser(request.resource.data)
        && request.resource.data.updatedAt == request.time;
      
      allow delete: if false; // Survival game, no deletion for now

      match /habits/{habitId} {
        allow get: if isOwner(userId) && isValidId(habitId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidId(habitId) && isValidHabit(request.resource.data);
        
        allow update: if isOwner(userId) && isValidId(habitId) && isValidHabit(request.resource.data);
        
        allow delete: if isOwner(userId) && isValidId(habitId);
      }

      match /logs/{logId} {
        allow get: if isOwner(userId) && isValidId(logId);
        allow list: if isOwner(userId); // Use with limit!
        
        allow create: if isOwner(userId) && isValidId(logId) && isValidLog(request.resource.data);
        
        // Logs are usually immutable
        allow update, delete: if false;
      }
    }
  }
}
